                                <TextRun>
                                  <Value>= chr(177)+
 chr(177)+
 CStr(SUM(Fields!TaxLiable.Value)) + chr(177)+
 CStr(SUM(Fields!TempSalesLineLineAmtTaxLiable.Value)) + chr(177)+
 First(Fields!BreakdownTitle.Value) + chr(177)+
 First(Fields!BreakdownLabel1.Value) + chr(177)+
 CStr(Fields!BreakdownAmt1.Value) + chr(177)+
 First(Fields!BreakdownLabel2.Value) + chr(177)+
 CStr(Fields!BreakdownAmt2.Value) + chr(177)+
First(Fields!BreakdownLabel3.Value) + chr(177)+
CStr(Fields!BreakdownAmt3.Value) + chr(177)+
First(Fields!BreakdownLabel4.Value) + chr(177)+
 CStr(Fields!BreakdownAmt4.Value)+ chr(177)+
               chr(177)+
CStr(SUM(Fields!AmountExclInvDisc.Value)) + chr(177)+
 chr(177)+
 CStr(SUM(Fields!TempSalesLineInvDiscAmt.Value)) + chr(177)+
 First(Fields!TotalTaxLabel.Value) + chr(177)+
 CStr(SUM(Fields!TaxAmount.Value)) + chr(177)+
                      chr(177)+
